---
import '../styles/typography.css';
import '../styles/global.css';
import '../styles/animations.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'AV Group — Proyectos Inmobiliarios de Lujo en Medellín',
  description = 'Veinte años desarrollando proyectos residenciales, vacacionales, oficinas, hoteles y wellness en El Poblado, Astorga, Alto de las Palmas y El Campestre.',
  image = '/og-image.jpg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const realEstateAgentJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateAgent',
  name: 'AV Group',
  description,
  url: Astro.site?.toString(),
  areaServed: ['Medellín', 'El Poblado', 'Astorga', 'Milla de Oro', 'Alto de las Palmas', 'Envigado', 'El Campestre', 'Colombia'],
  telephone: '+57 301 220 8586',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Cra. 30 #4 A - 45 Oficina 506A',
    addressLocality: 'Medellín',
    addressRegion: 'El Poblado',
    addressCountry: 'CO',
  },
  sameAs: [
    'https://www.instagram.com/avgroup.projects/',
    'https://www.tiktok.com/@avgroup.projects',
  ],
};
---

<!doctype html>
<html lang="es-CO">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#080808" />
    <meta name="color-scheme" content="dark" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site).toString()} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="AV Group" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).toString()} />

    <!-- JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(realEstateAgentJsonLd)}
    />
  </head>

  <body>
    <slot />
  </body>
</html>
