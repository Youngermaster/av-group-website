---
import Layout from '../../layouts/Layout.astro';
import Loader from '../../components/Loader.astro';
import Cursor from '../../components/Cursor.astro';
import Nav from '../../components/Nav.astro';
import MobileMenu from '../../components/MobileMenu.astro';
import Footer from '../../components/Footer.astro';
import NoiseOverlay from '../../components/NoiseOverlay.astro';
import PropertyCard from '../../components/PropertyCard.astro';
import SplatViewer from '../../components/SplatViewer.astro';
import ArrowRight from '../../components/icons/ArrowRight.astro';
import WhatsApp from '../../components/icons/WhatsApp.astro';
import Diamond from '../../components/icons/Diamond.astro';
import { properties, getRelatedProperties } from '../../data/properties';

export function getStaticPaths() {
  return properties.map((property) => ({
    params: { slug: property.slug },
    props: { property },
  }));
}

const { property } = Astro.props;
const related = getRelatedProperties(property.slug, 3);

const whatsappNumber = '573012208586';
const whatsappMsg = `Hola AV Group. Me interesa ${property.name} (${property.zone}, ${property.city}). ¿Podemos coordinar una visita privada?`;
const whatsappLink = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMsg)}`;

const title = `${property.name} — ${property.zone} · AV Group`;
const description = property.description[0];

const fmt = new Intl.NumberFormat('es-CO');
const areaFrom = fmt.format(property.areaRange.from);
const areaTo = fmt.format(property.areaRange.to);
---

<Layout title={title} description={description} image={property.image}>
  <Loader />
  <Cursor />
  <Nav />
  <MobileMenu />

  <main>
    <!-- Hero -->
    <section class="ph-hero" aria-label={property.name}>
      <div class="ph-hero__bg" aria-hidden="true">
        <img
          src={property.image}
          alt=""
          width="2200"
          height="1500"
          fetchpriority="high"
          decoding="async"
        />
      </div>
      <div class="ph-hero__veil" aria-hidden="true"></div>

      <div class="ph-hero__inner container">
        <a href="/#proyectos" class="ph-hero__back mono" aria-label="Volver a proyectos">
          ← Volver
        </a>

        <span class="ph-hero__category mono">{property.category}</span>

        <h1 class="ph-hero__title display">{property.name}</h1>

        <p class="ph-hero__zone mono">
          {property.zone} · {property.city}
        </p>

        <hr class="ph-hero__line" />

        <div class="ph-hero__meta-row">
          <span class="ph-hero__status mono">
            <Diamond size={9} /> {property.status}
          </span>
          {property.architect && (
            <span class="ph-hero__architect mono">
              Diseño · {property.architect}
            </span>
          )}
        </div>
      </div>

      <a href="#detalle" class="ph-hero__scroll mono" aria-label="Continuar">
        Continuar
        <span class="ph-hero__scroll-line" aria-hidden="true"></span>
      </a>
    </section>

    <!-- Quick stats -->
    <section id="detalle" class="ph-stats" aria-label="Especificaciones">
      <div class="container">
        <div class="ph-stats__grid">
          <div class="ph-stats__item">
            <span class="ph-stats__label mono">Categoría</span>
            <span class="ph-stats__value display">{property.category}</span>
          </div>
          <div class="ph-stats__item">
            <span class="ph-stats__label mono">Áreas</span>
            <span class="ph-stats__value display">{areaFrom}–{areaTo} m²</span>
          </div>
          <div class="ph-stats__item">
            <span class="ph-stats__label mono">Unidades</span>
            <span class="ph-stats__value display">
              {property.units.count > 0 ? property.units.count : '—'}
            </span>
          </div>
          <div class="ph-stats__item">
            <span class="ph-stats__label mono">Tipo</span>
            <span class="ph-stats__value display ph-stats__value--small">{property.units.noun}</span>
          </div>
          {property.yearBuilt && (
            <div class="ph-stats__item">
              <span class="ph-stats__label mono">Entrega</span>
              <span class="ph-stats__value display">{property.yearBuilt}</span>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Description / narrative -->
    <section class="ph-narrative section" aria-label="Descripción">
      <div class="container ph-narrative__inner">
        <header class="ph-narrative__header">
          <p class="label-mono" data-reveal>◆ EL PROYECTO</p>
          <h2 class="display ph-narrative__title" data-reveal>
            Una visión<br />holística.
          </h2>
        </header>

        <div class="ph-narrative__body">
          {property.description.map((p) => (
            <p class="ph-narrative__p" data-reveal>{p}</p>
          ))}
        </div>
      </div>
    </section>

    {property.model && (
      <SplatViewer
        src={property.model.src}
        fileName={property.model.fileName}
        label={property.model.label}
        title={property.model.title}
        caption={property.model.caption}
        byteSize={property.model.byteSize}
      />
    )}

    <!-- Gallery -->
    <section class="ph-gallery" aria-label="Galería">
      <div class="container">
        <header class="ph-gallery__header">
          <p class="label-mono" data-reveal>◆ GALERÍA</p>
          <h2 class="display ph-gallery__title" data-reveal>El detalle es la diferencia.</h2>
        </header>

        <div class="ph-gallery__grid">
          {property.gallery.map((g, i) => (
            <figure class:list={['ph-gallery__item', `ph-gallery__item--${i}`]} data-reveal>
              <img
                src={g.src}
                alt={g.alt}
                width="1600"
                height="1200"
                loading="lazy"
                decoding="async"
                class="parallax-img"
              />
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="ph-features section" aria-label="Características">
      <div class="container">
        <header class="ph-features__header">
          <p class="label-mono" data-reveal>◆ CARACTERÍSTICAS</p>
          <h2 class="display ph-features__title" data-reveal>
            La curaduría detrás del piso.
          </h2>
        </header>

        <ul class="ph-features__list">
          {property.features.map((f, i) => (
            <li class="ph-feature" data-reveal data-reveal-delay={String(i * 0.05)}>
              <span class="ph-feature__num mono">{String(i + 1).padStart(2, '0')}</span>
              <span class="ph-feature__text">{f}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Location coordinates -->
    {property.coordinates && (
      <section class="ph-location" aria-label="Ubicación">
        <div class="container ph-location__inner">
          <p class="label-mono" data-reveal>◆ COORDENADAS</p>
          <p class="ph-location__coords mono" data-reveal>{property.coordinates}</p>
          <p class="ph-location__zone display" data-reveal>{property.zone}, {property.city}</p>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="ph-cta" aria-label="Solicitar visita">
      <div class="container ph-cta__inner">
        <p class="label-mono" data-reveal>◆ CONVERSACIÓN PRIVADA</p>
        <h2 class="display ph-cta__title" data-reveal>
          {property.name} merece<br />una conversación a la altura.
        </h2>
        <p class="ph-cta__sub mono" data-reveal>
          Coordina una visita o asesoría con uno de nuestros consultores.
        </p>

        <div class="ph-cta__actions" data-reveal>
          <a
            class="btn btn--solid ph-cta__btn"
            href={whatsappLink}
            target="_blank"
            rel="noopener"
          >
            <WhatsApp size={16} />
            <span>{property.invitation || 'Solicitar visita'}</span>
            <ArrowRight size={14} />
          </a>
          <a class="ph-cta__alt mono" href="/#contacto">
            O escribe a un asesor →
          </a>
        </div>
      </div>
    </section>

    <!-- Related -->
    {related.length > 0 && (
      <section class="ph-related section" aria-label="Otros proyectos">
        <div class="container">
          <header class="ph-related__header">
            <p class="label-mono" data-reveal>◆ OTROS PROYECTOS</p>
            <h2 class="display ph-related__title" data-reveal>
              Curaduría adyacente.
            </h2>
          </header>

          <div class="ph-related__grid">
            {related.map((p) => (
              <PropertyCard property={p} />
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
  <NoiseOverlay />
</Layout>

<script>
  import('../../scripts/main.ts');
</script>

<style>
  /* ============================================================
     Project hero
     ============================================================ */
  .ph-hero {
    position: relative;
    height: 92vh;
    height: 92dvh;
    min-height: 640px;
    overflow: hidden;
    isolation: isolate;
    background: var(--color-void);
  }

  .ph-hero__bg {
    position: absolute;
    inset: -4%;
    z-index: -2;
  }
  .ph-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.55;
    filter: saturate(0.78) contrast(1.08) brightness(0.7);
  }

  .ph-hero__veil {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(8,8,8,0.4) 0%, rgba(8,8,8,0.55) 50%, rgba(8,8,8,1) 100%),
      linear-gradient(90deg, rgba(8,8,8,0.6) 0%, rgba(8,8,8,0) 50%);
  }

  .ph-hero__inner {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-top: clamp(120px, 16vh, 180px);
    padding-bottom: clamp(80px, 12vh, 140px);
    gap: clamp(8px, 1.4vw, 18px);
  }

  .ph-hero__back {
    position: absolute;
    top: clamp(96px, 12vh, 130px);
    left: var(--container-pad);
    color: var(--color-silver);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    transition: color 0.3s var(--ease-luxury);
  }
  .ph-hero__back:hover { color: var(--color-gold); }

  .ph-hero__category {
    color: var(--color-gold);
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
  }

  .ph-hero__title {
    font-size: clamp(48px, 9vw, 130px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--color-white);
    font-weight: var(--weight-light);
    max-width: 14ch;
  }

  .ph-hero__zone {
    color: var(--color-silver);
    font-size: 12px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-top: 6px;
  }

  .ph-hero__line {
    width: 80px;
    height: 1px;
    border: 0;
    background: var(--color-gold);
    margin-top: 14px;
  }

  .ph-hero__meta-row {
    display: inline-flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
    margin-top: 6px;
  }

  .ph-hero__status {
    color: var(--color-gold);
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .ph-hero__architect {
    color: var(--color-silver);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }

  .ph-hero__scroll {
    position: absolute;
    right: var(--container-pad);
    bottom: clamp(40px, 6vh, 80px);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    color: var(--color-silver);
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }
  .ph-hero__scroll-line {
    width: 1px;
    height: 50px;
    background: var(--color-gold-muted);
  }

  /* ============================================================
     Stats strip
     ============================================================ */
  .ph-stats {
    background: var(--color-obsidian);
    border-bottom: var(--border-thin);
    padding: clamp(40px, 5vw, 64px) 0;
  }

  .ph-stats__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
  }

  .ph-stats__item {
    padding: 0 clamp(12px, 2vw, 24px);
    border-left: var(--border-thin);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ph-stats__item:first-child { border-left: 0; }

  .ph-stats__label {
    color: var(--color-dim);
    font-size: 10px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
  }

  .ph-stats__value {
    color: var(--color-white);
    font-size: clamp(20px, 2vw, 28px);
    font-weight: var(--weight-light);
    line-height: 1.15;
  }
  .ph-stats__value--small {
    font-size: clamp(13px, 1.1vw, 16px);
    color: var(--color-silver);
  }

  @media (max-width: 768px) {
    .ph-stats__grid {
      grid-template-columns: 1fr 1fr;
      gap: 24px 0;
    }
    .ph-stats__item {
      padding: 12px 16px;
      border-left: 0;
      border-top: var(--border-thin);
    }
    .ph-stats__item:first-child,
    .ph-stats__item:nth-child(2) { border-top: 0; }
  }

  /* ============================================================
     Narrative
     ============================================================ */
  .ph-narrative {
    background: var(--color-void);
  }
  .ph-narrative__inner {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(40px, 6vw, 100px);
    align-items: start;
  }

  .ph-narrative__title {
    margin-top: 24px;
    font-size: var(--text-title);
    line-height: 1.1;
    color: var(--color-white);
    font-weight: var(--weight-light);
    letter-spacing: -0.01em;
  }

  .ph-narrative__body {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ph-narrative__p {
    color: var(--color-silver);
    font-size: clamp(15px, 1.2vw, 17px);
    line-height: 1.85;
    font-weight: var(--weight-light);
  }

  @media (max-width: 1024px) {
    .ph-narrative__inner { grid-template-columns: 1fr; }
  }

  /* ============================================================
     Gallery
     ============================================================ */
  .ph-gallery {
    background: var(--color-void);
    padding-bottom: var(--space-section);
  }

  .ph-gallery__header {
    margin-bottom: clamp(40px, 5vw, 64px);
  }

  .ph-gallery__title {
    margin-top: 18px;
    font-size: var(--text-title);
    color: var(--color-white);
    font-weight: var(--weight-light);
  }

  .ph-gallery__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    grid-template-rows: auto auto;
    gap: clamp(12px, 1.5vw, 24px);
  }

  .ph-gallery__item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    margin: 0;
    background: var(--color-charcoal);
  }
  .ph-gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s var(--ease-luxury);
  }
  .ph-gallery__item:hover img { transform: scale(1.05); }

  .ph-gallery__item--0 {
    grid-column: 1 / 2;
    grid-row: 1 / 3;
    aspect-ratio: auto;
  }
  .ph-gallery__item--1 { grid-column: 2 / 3; grid-row: 1 / 2; }
  .ph-gallery__item--2 { grid-column: 2 / 3; grid-row: 2 / 3; }
  .ph-gallery__item--3 {
    grid-column: 1 / 3;
    aspect-ratio: 21 / 9;
  }

  @media (max-width: 768px) {
    .ph-gallery__grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }
    .ph-gallery__item,
    .ph-gallery__item--0,
    .ph-gallery__item--1,
    .ph-gallery__item--2,
    .ph-gallery__item--3 {
      grid-column: auto;
      grid-row: auto;
      aspect-ratio: 4 / 3;
    }
  }

  /* ============================================================
     Features
     ============================================================ */
  .ph-features {
    background: var(--color-obsidian);
  }

  .ph-features__header {
    margin-bottom: clamp(40px, 5vw, 64px);
    max-width: 800px;
  }

  .ph-features__title {
    margin-top: 18px;
    font-size: var(--text-title);
    color: var(--color-white);
    font-weight: var(--weight-light);
  }

  .ph-features__list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: var(--border-thin);
  }

  .ph-feature {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding: clamp(22px, 2.4vw, 32px) clamp(8px, 1.5vw, 20px);
    border-bottom: var(--border-thin);
  }

  .ph-feature:nth-child(odd) {
    border-right: var(--border-thin);
  }

  .ph-feature__num {
    color: var(--color-gold);
    font-size: 11px;
    letter-spacing: 0.3em;
    flex-shrink: 0;
    padding-top: 2px;
  }

  .ph-feature__text {
    color: var(--color-silver);
    font-size: 14px;
    line-height: 1.7;
    font-weight: var(--weight-light);
  }

  @media (max-width: 768px) {
    .ph-features__list { grid-template-columns: 1fr; }
    .ph-feature:nth-child(odd) { border-right: 0; }
  }

  /* ============================================================
     Location
     ============================================================ */
  .ph-location {
    background: var(--color-void);
    padding: clamp(80px, 12vw, 160px) 0;
    text-align: center;
    border-top: var(--border-thin);
    border-bottom: var(--border-thin);
  }
  .ph-location__inner {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .ph-location__coords {
    color: var(--color-gold);
    font-size: clamp(14px, 1.2vw, 18px);
    letter-spacing: 0.4em;
  }
  .ph-location__zone {
    color: var(--color-white);
    font-size: clamp(28px, 4vw, 56px);
    font-weight: var(--weight-light);
  }

  /* ============================================================
     CTA
     ============================================================ */
  .ph-cta {
    background: var(--color-obsidian);
    padding: clamp(100px, 14vw, 180px) 0;
  }
  .ph-cta__inner {
    max-width: 900px;
    text-align: center;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .ph-cta__title {
    margin-top: 12px;
    font-size: var(--text-title);
    line-height: 1.1;
    color: var(--color-white);
    font-weight: var(--weight-light);
  }
  .ph-cta__sub {
    color: var(--color-silver);
    font-size: 12px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-top: 4px;
  }
  .ph-cta__actions {
    display: inline-flex;
    align-items: center;
    gap: 24px;
    margin-top: 32px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .ph-cta__btn {
    padding: 18px 32px;
    min-width: 280px;
    gap: 12px;
  }
  .ph-cta__alt {
    color: var(--color-silver);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    transition: color 0.3s var(--ease-luxury);
  }
  .ph-cta__alt:hover { color: var(--color-gold); }

  /* ============================================================
     Related
     ============================================================ */
  .ph-related {
    background: var(--color-void);
  }
  .ph-related__header {
    margin-bottom: clamp(40px, 5vw, 64px);
  }
  .ph-related__title {
    margin-top: 18px;
    font-size: var(--text-title);
    color: var(--color-white);
    font-weight: var(--weight-light);
  }
  .ph-related__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(16px, 2vw, 32px);
  }
  @media (max-width: 1024px) {
    .ph-related__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 768px) {
    .ph-related__grid { grid-template-columns: 1fr; }
  }
</style>
