---
const lines = [
  'Para los inconformes,',
  'aquellos que quieren',
  'siempre algo más.',
];
---

<section id="manifiesto" class="manifesto section" aria-label="Manifiesto AV Group" data-manifesto>
  <div class="container manifesto__inner">
    <p class="label-mono manifesto__eyebrow">◆ MANIFIESTO</p>
    <h2 class="manifesto__text display">
      {lines.map((l) => (
        <span class="manifesto__line"><span class="manifesto__line-inner">{l}</span></span>
      ))}
    </h2>
    <p class="manifesto__year mono">— Una visión holística · 20 años</p>
    <hr class="manifesto__divider" />
  </div>
</section>

<style>
  .manifesto {
    background: var(--color-void);
    text-align: left;
  }

  .manifesto__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .manifesto__eyebrow {
    margin-bottom: clamp(48px, 8vw, 96px);
  }

  .manifesto__text {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--text-display);
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--color-white);
    margin: 0;
  }

  .manifesto__line {
    display: block;
    overflow: hidden;
  }

  .manifesto__line-inner {
    display: inline-block;
    /* Initial state: hidden via clip-path; GSAP animates */
    clip-path: inset(0 100% 0 0);
    will-change: clip-path;
  }
  .manifesto__line-inner.is-revealed {
    clip-path: inset(0 0% 0 0);
    transition: clip-path 1.2s var(--ease-luxury);
  }

  .manifesto__year {
    margin-top: clamp(48px, 6vw, 80px);
    font-size: 11px;
    letter-spacing: 0.4em;
    color: var(--color-dim);
    text-transform: uppercase;
  }

  .manifesto__divider {
    margin-top: clamp(60px, 8vw, 100px);
    border: 0;
    height: 1px;
    background: linear-gradient(90deg, var(--color-gold-muted), transparent);
  }
</style>
