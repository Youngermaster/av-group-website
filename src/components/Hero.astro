---
import Diamond from './icons/Diamond.astro';
import ChevronDown from './icons/ChevronDown.astro';

// Hero image: AV Group's Selvavignon exterior — flagship project.
const heroImg = 'https://avgrouprojects.com/cdn/shop/files/Exterior2_1.jpg';
---

<section class="hero" aria-label="AV Group — Inicio">
  <!-- Layer 1: photographic background -->
  <div class="hero__layer hero__layer--bg parallax-layer" data-depth="0.4" aria-hidden="true">
    <img
      src={heroImg}
      alt=""
      width="2400"
      height="1600"
      fetchpriority="high"
      decoding="async"
    />
  </div>

  <!-- Layer 2: gold linework / architectural marks (mid-depth) -->
  <div class="hero__layer hero__layer--marks parallax-layer" data-depth="0.85" aria-hidden="true">
    <svg viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
      <g stroke="rgba(184,150,90,0.25)" stroke-width="0.5" fill="none">
        <line x1="120" y1="0" x2="120" y2="900" />
        <line x1="1320" y1="0" x2="1320" y2="900" />
        <line x1="0" y1="120" x2="1440" y2="120" />
        <line x1="0" y1="780" x2="1440" y2="780" />
      </g>
      <g fill="rgba(184,150,90,0.4)">
        <circle cx="120" cy="120" r="2" />
        <circle cx="1320" cy="120" r="2" />
        <circle cx="120" cy="780" r="2" />
        <circle cx="1320" cy="780" r="2" />
      </g>
    </svg>
  </div>

  <!-- Layer 3: gradient overlay (darkens to readable) -->
  <div class="hero__layer hero__layer--overlay" aria-hidden="true"></div>

  <!-- Layer 4: foreground type & content -->
  <div class="hero__inner">
    <div class="hero__eyebrow">
      <span class="label-mono"><Diamond size={9} /> Medellín · Colombia</span>
    </div>

    <h1 class="hero__title display" aria-label="AV Group — Una visión holística">
      <span class="hero__title-row">A<span class="hero__o" aria-hidden="true">V</span></span>
      <span class="hero__italic">GROUP</span>
    </h1>

    <hr class="hero__line" aria-hidden="true" />

    <p class="hero__subtitle mono">
      Proyectos inmobiliarios de lujo<br />
      Una visión holística
    </p>

    <a href="#descubrir" class="hero__scroll" aria-label="Desplazar para descubrir">
      <span class="hero__scroll-text mono">DESCUBRIR</span>
      <span class="hero__scroll-line" aria-hidden="true"></span>
      <ChevronDown size={14} />
    </a>
  </div>

  <!-- Stats bar (bottom) -->
  <div class="hero__stats" aria-label="Estadísticas">
    <div class="hero__stat">
      <span class="hero__stat-label mono">SEDE</span>
      <span class="hero__stat-value display">El Poblado, Medellín</span>
    </div>
    <div class="hero__stat">
      <span class="hero__stat-label mono">PROYECTOS</span>
      <span class="hero__stat-value display"><span data-counter="17">0</span></span>
    </div>
    <div class="hero__stat">
      <span class="hero__stat-label mono">AÑOS</span>
      <span class="hero__stat-value display"><span data-counter="20">0</span>+</span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    min-height: 640px;
    overflow: hidden;
    isolation: isolate;
    background: var(--color-void);
  }

  .hero__layer {
    position: absolute;
    inset: -6%;
    /*
     * No permanent will-change. The tilt-parallax loop sets transform via
     * translate3d() which already promotes the layer to its own compositor
     * tier for the duration of motion. Permanent will-change was holding
     * a layer reservation indefinitely and increasing memory pressure on iOS.
     */
  }

  .hero__layer--bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.55;
    filter: saturate(0.78) contrast(1.08) brightness(0.78);
  }

  .hero__layer--marks {
    inset: -2%;
    pointer-events: none;
  }
  .hero__layer--marks svg {
    width: 100%;
    height: 100%;
  }

  .hero__layer--overlay {
    inset: 0;
    background: var(--gradient-hero);
    pointer-events: none;
    z-index: 1;
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-left: var(--container-pad);
    padding-right: var(--container-pad);
    padding-bottom: clamp(140px, 18vh, 200px);
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--color-gold);
    margin-bottom: clamp(24px, 3vw, 40px);
  }
  .hero__eyebrow .label-mono {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .hero__title {
    color: var(--color-white);
    font-size: var(--text-hero);
    line-height: 0.85;
    letter-spacing: -0.025em;
    font-weight: var(--weight-light);
    margin: 0;
  }

  .hero__title-row {
    display: block;
    overflow: hidden;
  }

  .hero__o {
    display: inline-block;
    color: var(--color-gold);
    font-style: italic;
  }

  .hero__italic {
    display: block;
    font-style: italic;
    font-weight: 200;
    padding-left: 12%;
    overflow: hidden;
    color: var(--color-white);
  }

  .hero__line {
    width: 80px;
    height: 1px;
    border: 0;
    background: var(--color-gold);
    margin: clamp(28px, 4vw, 48px) 0;
    transform-origin: left center;
  }

  .hero__subtitle {
    color: var(--color-silver);
    font-family: var(--font-body);
    font-weight: var(--weight-thin);
    font-size: clamp(13px, 1vw, 15px);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    line-height: 1.7;
    max-width: 32ch;
  }

  .hero__scroll {
    position: absolute;
    right: var(--container-pad);
    bottom: clamp(170px, 22vh, 240px);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    color: var(--color-silver);
    font-size: 10px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    transition: color var(--duration-fast) var(--ease-luxury);
  }
  .hero__scroll:hover { color: var(--color-gold); }
  .hero__scroll-text {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }
  .hero__scroll-line {
    width: 1px;
    height: 50px;
    background: var(--color-gold-muted);
    transform-origin: top;
    animation: pento-scroll-line 2.6s ease-in-out infinite;
  }
  .hero__scroll svg {
    animation: pento-bounce 2s ease-in-out infinite;
  }

  /* Stats bar */
  .hero__stats {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    padding: clamp(20px, 2.4vw, 32px) var(--container-pad);
    /* Solid + subtle alpha — drops backdrop-filter, which was repainting
       the entire cropped hero image behind it every frame during parallax. */
    background: rgba(8, 8, 8, 0.92);
    border-top: var(--border-thin);
    max-width: 100vw;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 0 clamp(12px, 2vw, 24px);
    border-left: var(--border-thin);
  }
  .hero__stat:first-child { border-left: 0; padding-left: 0; }

  .hero__stat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--color-dim);
  }

  .hero__stat-value {
    font-family: var(--font-display);
    font-weight: var(--weight-light);
    font-size: clamp(16px, 1.4vw, 22px);
    color: var(--color-white);
    letter-spacing: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero__inner { padding-bottom: clamp(180px, 26vh, 220px); }
    .hero__scroll { display: none; }
    .hero__stats {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 18px var(--container-pad);
    }
    .hero__stat {
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
      padding: 6px 0;
      border-left: 0;
      border-top: var(--border-thin);
    }
    .hero__stat:first-child { border-top: 0; }
    .hero__stat-value { font-size: 14px; }
  }

  /* Reveal helpers — initial states for GSAP entry */
  .hero__title :global(.char) { display: inline-block; will-change: transform, opacity; }
</style>
