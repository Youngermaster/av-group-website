---
const bg = 'https://avgrouprojects.com/cdn/shop/files/Vista_Atardecer_1.1_copia.png';
---

<section class="testimonial" aria-label="Testimonio AV Group">
  <div
    class="testimonial__bg"
    style={`background-image:url(${bg})`}
    aria-hidden="true"
  >
  </div>
  <div class="testimonial__veil" aria-hidden="true"></div>

  <div class="testimonial__inner container">
    <span class="testimonial__quote-open" aria-hidden="true">“</span>
    <blockquote class="testimonial__text display" data-reveal>
      Los proyectos transforman<br />
      el entorno que los rodea.<br />
      Esa es nuestra premisa.
    </blockquote>
    <footer class="testimonial__author">
      <span class="testimonial__rule" aria-hidden="true"></span>
      <p class="mono testimonial__author-name">AV Group · Manifiesto</p>
      <p class="mono testimonial__author-role">20 años en Medellín</p>
    </footer>
  </div>
</section>

<style>
  .testimonial {
    position: relative;
    isolation: isolate;
    padding: clamp(120px, 18vw, 220px) 0;
    overflow: hidden;
    background: var(--color-void);
  }

  .testimonial__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    /*
     * Previously used filter: blur(8px) on a fullscreen background image —
     * extremely expensive to repaint on every scroll. Replaced with a heavy
     * darken + slight desaturate approximated by the layered veil below;
     * the visual difference is minimal but scroll cost drops to ~zero.
     */
    opacity: 0.55;
    z-index: -2;
  }

  .testimonial__veil {
    position: absolute;
    inset: 0;
    /* Heavier veil compensates for removing the blur filter. */
    background:
      radial-gradient(
        circle at 50% 50%,
        rgba(8, 8, 8, 0.55),
        rgba(8, 8, 8, 0.95)
      ),
      linear-gradient(180deg, rgba(8, 8, 8, 0.7), rgba(8, 8, 8, 0.7));
    z-index: -1;
  }

  .testimonial__inner {
    position: relative;
    text-align: center;
    max-width: 1000px;
  }

  .testimonial__quote-open {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(140px, 18vw, 240px);
    line-height: 0.6;
    color: var(--color-gold-muted);
    opacity: 0.4;
    margin-bottom: -40px;
  }

  .testimonial__text {
    font-style: italic;
    font-weight: var(--weight-light);
    font-size: clamp(24px, 3.2vw, 44px);
    line-height: 1.4;
    color: var(--color-white);
    letter-spacing: -0.005em;
    max-width: 24ch;
    margin: 0 auto;
  }

  .testimonial__author {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-top: clamp(60px, 8vw, 100px);
  }

  .testimonial__rule {
    width: 40px;
    height: 1px;
    background: var(--color-gold);
    display: block;
    margin-bottom: 14px;
  }

  .testimonial__author-name {
    font-size: 13px;
    letter-spacing: 0.3em;
    color: var(--color-white);
    text-transform: uppercase;
  }

  .testimonial__author-role {
    font-size: 11px;
    letter-spacing: 0.3em;
    color: var(--color-silver);
    text-transform: uppercase;
  }
</style>
