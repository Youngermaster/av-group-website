---
interface Props { class?: string; size?: number }
const { class: className, size = 24 } = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  class={className}
  fill="none"
  stroke="currentColor"
  stroke-width="1"
  stroke-linecap="square"
  aria-hidden="true"
>
  <line x1="4" y1="8" x2="20" y2="8" />
  <line x1="4" y1="16" x2="20" y2="16" />
</svg>
