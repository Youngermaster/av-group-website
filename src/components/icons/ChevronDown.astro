---
interface Props { class?: string; size?: number }
const { class: className, size = 12 } = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  class={className}
  fill="none"
  stroke="currentColor"
  stroke-width="1"
  stroke-linecap="square"
  aria-hidden="true"
>
  <polyline points="6,9 12,15 18,9" />
</svg>
