---
// Photographic grain — fixed overlay across whole site.
---

<svg class="noise-overlay" aria-hidden="true">
  <filter id="pento-noise">
    <feTurbulence
      type="fractalNoise"
      baseFrequency="0.7"
      numOctaves="2"
      stitchTiles="stitch"
    />
    <feColorMatrix type="saturate" values="0" />
  </filter>
  <rect width="100%" height="100%" filter="url(#pento-noise)" />
</svg>

<style>
  .noise-overlay {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 9998;
    opacity: 0.06;
    pointer-events: none;
    /*
     * NOTE: previously used mix-blend-mode: overlay which forces every
     * underlying paint to recomposite against this layer on scroll —
     * a serious scroll-jank source on long pages. Plain opacity gives a
     * very similar grain effect with zero composite cost.
     */
  }

  @media (prefers-reduced-motion: reduce) {
    .noise-overlay { opacity: 0.03; }
  }
</style>
